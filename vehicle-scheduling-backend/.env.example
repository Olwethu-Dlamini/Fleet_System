# ============================================================
# FleetScheduler Pro — Environment Variables Example
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Server Configuration ─────────────────────────────────────
# Port the API server listens on
PORT=3000

# Node environment (development | production | test)
NODE_ENV=production

# Log level (trace | debug | info | warn | error | fatal)
# Defaults to 'info' in production, 'debug' in development
LOG_LEVEL=info

# ── Database ─────────────────────────────────────────────────
# MySQL host (use 'db' when running inside Docker Compose)
DB_HOST=localhost

# MySQL port (default: 3306)
DB_PORT=3306

# MySQL database name
DB_NAME=vehicle_scheduling

# MySQL username
DB_USER=root

# MySQL password
DB_PASSWORD=

# MySQL root password (Docker Compose only — not used by the API)
DB_ROOT_PASSWORD=changeme

# ── Authentication ────────────────────────────────────────────
# JWT signing secret — REQUIRED. Server will not start without this.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-replace-this

# JWT token expiry duration (default: 8h)
# Accepts zeit/ms format: 1h, 8h, 7d, etc.
JWT_EXPIRES=8h

# ── Email (SMTP) ──────────────────────────────────────────────
# Optional — email notifications are disabled when SMTP_HOST is not set.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASS=your-smtp-password

# ── Firebase Cloud Messaging (Push Notifications) ─────────────
# Optional — push notifications are disabled when not set.
# Path to your Firebase Admin SDK service account JSON file.
# Download from: Firebase Console > Project Settings > Service accounts
FCM_SERVICE_ACCOUNT_PATH=/path/to/firebase-service-account.json

# ── Google Maps ───────────────────────────────────────────────
# Optional — GPS directions feature is disabled when not set.
# Requires Google Routes API v2 enabled in your Google Cloud project.
# Keep this server-side only — never expose to Flutter clients.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Emerald v6 Integration (Optional) ────────────────────────
# Connect to an Emerald v6 billing/service management system
# to sync customers and work orders into FleetScheduler.
# All three values are required for the integration to work.
EMERALD_API_URL=https://your-emerald-server.com
EMERALD_API_USER=your-emerald-username
EMERALD_API_PASSWORD=your-emerald-password

# Set to 'true' to enable sync endpoints (POST /api/emerald/sync/*)
# When false, sync endpoints return 400. Status check still works.
EMERALD_SYNC_ENABLED=false
